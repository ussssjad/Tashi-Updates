# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in DISCORD_BOT_TOKEN.
# On Railway/Render, set these directly in the dashboard instead.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────

# Your bot token from https://discord.com/developers/applications
# (Bot → Reset Token → copy the new value)
DISCORD_BOT_TOKEN=your_token_here

# Team lead's Discord user ID (already filled in)
TEAM_LEAD_ID=1463220939151114460

# Comma-separated list of team member user IDs
# Add more like: MEMBER_IDS=1434957366578643074,123456789012345678
MEMBER_IDS=1434957366578643074

# Daily reminder time (24-hour clock)
REMINDER_HOUR=20
REMINDER_MINUTE=0

# IANA timezone name — see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Karachi

# How long (seconds) a member has to complete their submission after accepting
SUBMISSION_TIMEOUT_SECONDS=3600
